      function renderShareCard() {
        var ctx = shareCanvas.getContext("2d");
        var W = 400, H = 520;
        var grad = ctx.createLinearGradient(0, 0, W, H);
        grad.addColorStop(0, "#080d1a");
        grad.addColorStop(0.5, "#0f172a");
        grad.addColorStop(1, "#1a0a2e");
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);
        ctx.textAlign = "center";

        // Brand
        ctx.font = "bold 22px sans-serif";
        ctx.fillStyle = "#db2777";
        ctx.fillText("Rizzora", W/2, 40);
        ctx.font = "9px sans-serif";
        ctx.fillStyle = "#64748b";
        ctx.fillText("MY PROGRESS CARD", W/2, 56);

        // Divider
        ctx.strokeStyle = "rgba(30,41,59,0.5)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(40, 70);
        ctx.lineTo(W-40, 70);
        ctx.stroke();

        // Rizz Score Circle
        var scoreR = 45;
        var cx = W/2, cy = 140;
        ctx.beginPath();
        ctx.arc(cx, cy, scoreR, 0, Math.PI*2);
        ctx.strokeStyle = "rgba(219,39,119,0.2)";
        ctx.lineWidth = 6;
        ctx.stroke();
        ctx.beginPath();
        ctx.arc(cx, cy, scoreR, -Math.PI/2, -Math.PI/2 + (Math.PI*2*Math.min(latestScore,100)/100));
        ctx.strokeStyle = "#db2777";
        ctx.lineWidth = 6;
        ctx.stroke();
        ctx.font = "bold 36px sans-serif";
        ctx.fillStyle = "#ffffff";
        ctx.fillText(latestScore, cx, cy + 12);
        ctx.font = "10px sans-serif";
        ctx.fillStyle = "#94a3b8";
        ctx.fillText("/100", cx, cy + 28);
        ctx.font = "bold 11px sans-serif";
        ctx.fillStyle = "#db2777";
        ctx.fillText("RIZZ SCORE", cx, cy - 58);

        // Stats grid
        var statsY = 210;
        var statItems = [
          { label: "LEVEL", value: currentLevel + "", sub: levelTitle, color: "#a855f7" },
          { label: "TOTAL XP", value: totalXP.toLocaleString(), sub: "Earned", color: "#8b5cf6" },
          { label: "STREAK", value: mainStreak + " Days", sub: "Current", color: "#f59e0b" },
          { label: "ACTIVITIES", value: totalActivities + "", sub: featuresUsedCount + " features", color: "#10b981" }
        ];
        var colW = (W - 80) / 4;
        for (var i = 0; i < statItems.length; i++) {
          var sx = 40 + colW * i + colW / 2;
          ctx.font = "8px sans-serif";
          ctx.fillStyle = "#64748b";
          ctx.fillText(statItems[i].label, sx, statsY);
          ctx.font = "bold 18px sans-serif";
          ctx.fillStyle = statItems[i].color;
          ctx.fillText(statItems[i].value, sx, statsY + 22);
          ctx.font = "8px sans-serif";
          ctx.fillStyle = "#64748b";
          ctx.fillText(statItems[i].sub, sx, statsY + 34);
        }

        // Divider
        ctx.beginPath();
        ctx.moveTo(40, statsY + 50);
        ctx.lineTo(W-40, statsY + 50);
        ctx.stroke();

        // Feature stats
        var fy = statsY + 70;
        ctx.font = "bold 10px sans-serif";
        ctx.fillStyle = "#94a3b8";
        ctx.textAlign = "left";
        ctx.fillText("FEATURE STATS", 40, fy);
        ctx.textAlign = "center";
        fy += 20;
        var featureData = [
          { icon: "🗣️", label: "Simulator", count: simSessions.length },
          { icon: "🔥", label: "Challenge", count: (challenge.completedDays||[]).length + "/30" },
          { icon: "🎯", label: "Crush Mode", count: crushActivities.length },
          { icon: "🔍", label: "Interest", count: interestChecks.length },
          { icon: "✨", label: "Profile", count: profileScores.length },
          { icon: "⚡", label: "Messaging", count: flirtActivities.length + wstiActivities.length }
        ];
        var fcolW = (W - 80) / 3;
        for (var i = 0; i < featureData.length; i++) {
          var row = Math.floor(i / 3);
          var col = i % 3;
          var fx = 40 + fcolW * col + fcolW / 2;
          var ffy = fy + row * 40;
          ctx.font = "16px sans-serif";
          ctx.fillStyle = "#ffffff";
          ctx.fillText(featureData[i].icon, fx, ffy);
          ctx.font = "8px sans-serif";
          ctx.fillStyle = "#94a3b8";
          ctx.fillText(featureData[i].label, fx, ffy + 14);
          ctx.font = "bold 14px sans-serif";
          ctx.fillStyle = "#e2e8f0";
          ctx.fillText(String(featureData[i].count), fx, ffy + 28);
        }

        // Footer
        ctx.beginPath();
        ctx.moveTo(40, H - 50);
        ctx.lineTo(W-40, H - 50);
        ctx.stroke();
        ctx.font = "8px sans-serif";
        ctx.fillStyle = "#475569";
        ctx.fillText("Generated on " + new Date().toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }), W/2, H - 30);
        ctx.fillStyle = "#64748b";
        ctx.fillText("rizzora.app — Your Dating Confidence Coach", W/2, H - 16);
      }

      document.getElementById("share-download").addEventListener("click", function () {
        var link = document.createElement("a");
        link.download = "rizzora-progress.png";
        link.href = shareCanvas.toDataURL("image/png");
        link.click();
      });

      document.getElementById("share-copy").addEventListener("click", function () {
        shareCanvas.toBlob(function (blob) {
          if (navigator.clipboard && navigator.clipboard.write) {
            var item = new ClipboardItem({ "image/png": blob });
            navigator.clipboard.write([item]).then(function () {
              document.getElementById("share-copy").textContent = "Copied!";
              setTimeout(function () { document.getElementById("share-copy").textContent = "Copy to Clipboard"; }, 2000);
            });
          }
        });
      });
    })();
  </script>
</Layout>
