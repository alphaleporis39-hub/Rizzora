---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
---

<Layout title="My Progress | Rizzora">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-10" id="prog-root">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-8">
      <div>
        <a href="/dashboard" class="text-xs font-semibold text-rose-400 hover:underline flex items-center gap-1 mb-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white" id="prog-greeting">My Progress</h1>
        <p class="text-slate-400 mt-1 text-sm">Your complete Rizzora journey — scores, growth, achievements & milestones.</p>
      </div>
      <button id="prog-share-btn" class="px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-white bg-linear-to-r from-rose-500 to-violet-500 rounded-full hover:scale-105 transition shadow-lg shadow-rose-500/20 shrink-0 cursor-pointer">
        Share Progress Card
      </button>
    </div>

    <!-- Empty State -->
    <div id="prog-empty" class="hidden max-w-lg mx-auto text-center glass p-10 sm:p-14 rounded-2xl">
      <div class="text-5xl mb-4">📊</div>
      <h3 class="text-lg font-bold text-slate-300">No activity yet</h3>
      <p class="text-sm text-slate-500 mt-2">Start using Rizzora features to see your progress here. Try a Conversation Simulation or take the 30-Day Challenge!</p>
      <a href="/conversation-simulator" class="inline-block mt-6 px-6 py-3 text-sm font-bold uppercase tracking-wider text-white bg-linear-to-r from-rose-500 to-violet-500 hover:from-rose-600 hover:to-violet-600 rounded-2xl transition">Start First Session</a>
    </div>

    <!-- Progress Content -->
    <div id="prog-content" class="hidden space-y-8">

      <!-- QUICK STATS -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="glass p-5 rounded-xl border border-brand-border/60 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 w-20 h-20 bg-rose-500/10 rounded-full blur-xl"></div>
          <span class="text-[10px] uppercase font-bold text-slate-500 block">Rizz Score</span>
          <div class="text-2xl font-black mt-2 text-rose-400" id="qs-rizz-score">—</div>
          <span class="text-[10px] text-slate-400 block mt-1" id="qs-rizz-change">No data yet</span>
        </div>
        <div class="glass p-5 rounded-xl border border-brand-border/60 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 w-20 h-20 bg-violet-500/10 rounded-full blur-xl"></div>
          <span class="text-[10px] uppercase font-bold text-slate-500 block">Total XP</span>
          <div class="text-2xl font-black mt-2 text-violet-400" id="qs-xp">—</div>
          <span class="text-[10px] text-slate-400 block mt-1" id="qs-level">Level 1</span>
        </div>
        <div class="glass p-5 rounded-xl border border-brand-border/60 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 w-20 h-20 bg-amber-500/10 rounded-full blur-xl"></div>
          <span class="text-[10px] uppercase font-bold text-slate-500 block">Current Streak</span>
          <div class="text-2xl font-black mt-2 text-amber-400" id="qs-streak">0 Days</div>
          <span class="text-[10px] text-slate-400 block mt-1" id="qs-streak-sub">Keep it going!</span>
        </div>
        <div class="glass p-5 rounded-xl border border-brand-border/60 relative overflow-hidden">
          <div class="absolute -right-4 -top-4 w-20 h-20 bg-emerald-500/10 rounded-full blur-xl"></div>
          <span class="text-[10px] uppercase font-bold text-slate-500 block">Total Activities</span>
          <div class="text-2xl font-black mt-2 text-emerald-400" id="qs-total">0</div>
          <span class="text-[10px] text-slate-400 block mt-1" id="qs-total-sub">Sessions completed</span>
        </div>
      </div>

      <!-- CHARTS -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="glass p-6 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-4">Rizz Score Trend</h3>
          <div class="relative h-40" id="chart-rizz">
            <div class="absolute inset-0 flex items-end justify-between gap-1 px-1" id="chart-rizz-bars"></div>
            <div class="absolute bottom-0 left-0 right-0 h-px bg-brand-border/40"></div>
          </div>
          <div class="flex justify-between text-[9px] text-slate-500 mt-2 px-1" id="chart-rizz-labels"></div>
        </div>
        <div class="glass p-6 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-4">XP Growth</h3>
          <div class="relative h-40" id="chart-xp">
            <div class="absolute inset-0 flex items-end justify-between gap-1 px-1" id="chart-xp-bars"></div>
            <div class="absolute bottom-0 left-0 right-0 h-px bg-brand-border/40"></div>
          </div>
          <div class="flex justify-between text-[9px] text-slate-500 mt-2 px-1" id="chart-xp-labels"></div>
        </div>
        <div class="glass p-6 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-4">Activity Breakdown</h3>
          <div id="chart-activity" class="space-y-3"></div>
        </div>
      </div>

      <!-- FEATURE PROGRESS CARDS -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="glass p-5 rounded-2xl border border-brand-border/60">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔥</span>
            <div>
              <h4 class="text-sm font-bold text-slate-200">30-Day Challenge</h4>
              <span class="text-[10px] text-slate-500" id="fp-challenge-status">Not started</span>
            </div>
          </div>
          <div class="w-full bg-slate-800 rounded-full h-2 mb-2">
            <div id="fp-challenge-bar" class="bg-linear-to-r from-rose-500 to-orange-500 h-2 rounded-full transition-all duration-700" style="width:0%"></div>
          </div>
          <div class="flex justify-between text-[10px] text-slate-500">
            <span id="fp-challenge-days">0 / 30 days</span>
            <span id="fp-challenge-xp">0 XP earned</span>
          </div>
        </div>
        <div class="glass p-5 rounded-2xl border border-brand-border/60">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🗣️</span>
            <div>
              <h4 class="text-sm font-bold text-slate-200">Conversation Simulator</h4>
              <span class="text-[10px] text-slate-500" id="fp-sim-status">No sessions</span>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-2 text-center mt-3">
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-emerald-400" id="fp-sim-count">0</div>
              <div class="text-[9px] text-slate-500">Sessions</div>
            </div>
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-rose-400" id="fp-sim-avg">0</div>
              <div class="text-[9px] text-slate-500">Avg Score</div>
            </div>
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-violet-400" id="fp-sim-best">0</div>
              <div class="text-[9px] text-slate-500">Best Score</div>
            </div>
          </div>
        </div>
        <div class="glass p-5 rounded-2xl border border-brand-border/60">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🎯</span>
            <div>
              <h4 class="text-sm font-bold text-slate-200">Crush Mode</h4>
              <span class="text-[10px] text-slate-500" id="fp-crush-status">No activity</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center mt-3">
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-pink-400" id="fp-crush-count">0</div>
              <div class="text-[9px] text-slate-500">Sessions</div>
            </div>
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-amber-400" id="fp-crush-xp">0</div>
              <div class="text-[9px] text-slate-500">XP Earned</div>
            </div>
          </div>
        </div>
        <div class="glass p-5 rounded-2xl border border-brand-border/60">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔍</span>
            <div>
              <h4 class="text-sm font-bold text-slate-200">Interest Check</h4>
              <span class="text-[10px] text-slate-500" id="fp-interest-status">No checks done</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center mt-3">
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-indigo-400" id="fp-interest-count">0</div>
              <div class="text-[9px] text-slate-500">Checks Done</div>
            </div>
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-emerald-400" id="fp-interest-xp">0</div>
              <div class="text-[9px] text-slate-500">XP Earned</div>
            </div>
          </div>
        </div>
        <div class="glass p-5 rounded-2xl border border-brand-border/60">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">✨</span>
            <div>
              <h4 class="text-sm font-bold text-slate-200">Profile Coach</h4>
              <span class="text-[10px] text-slate-500" id="fp-profile-status">No profiles checked</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center mt-3">
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-pink-400" id="fp-profile-count">0</div>
              <div class="text-[9px] text-slate-500">Reviews</div>
            </div>
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-amber-400" id="fp-profile-avg">0%</div>
              <div class="text-[9px] text-slate-500">Avg Score</div>
            </div>
          </div>
        </div>
        <div class="glass p-5 rounded-2xl border border-brand-border/60">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">⚡</span>
            <div>
              <h4 class="text-sm font-bold text-slate-200">Messaging Tools</h4>
              <span class="text-[10px] text-slate-500" id="fp-messaging-status">No messages reworked</span>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center mt-3">
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-amber-400" id="fp-flirt-count">0</div>
              <div class="text-[9px] text-slate-500">Flirt Coach</div>
            </div>
            <div class="bg-slate-900/60 rounded-lg p-2">
              <div class="text-lg font-bold text-sky-400" id="fp-wsti-count">0</div>
              <div class="text-[9px] text-slate-500">WSTI Texts</div>
            </div>
          </div>
        </div>
      </div>

      <!-- STRENGTHS & IMPROVEMENT -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="glass p-6 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-emerald-400 mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400"></span> Your Strengths
          </h3>
          <div id="prog-strengths" class="space-y-3"></div>
        </div>
        <div class="glass p-6 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-amber-400 mb-4 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-amber-400"></span> Areas to Improve
          </h3>
          <div id="prog-improve" class="space-y-3"></div>
        </div>
      </div>

      <!-- ACHIEVEMENTS -->
      <div class="glass p-6 rounded-2xl">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-4 border-b border-brand-border/40 pb-3">Achievements & Badges</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3" id="prog-achievements"></div>
      </div>

      <!-- RECENT MILESTONES -->
      <div class="glass p-6 rounded-2xl">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-4 border-b border-brand-border/40 pb-3">Recent Milestones</h3>
        <div id="prog-milestones" class="space-y-3"></div>
      </div>

      <!-- YOUR GROWTH -->
      <div class="glass-accent p-6 rounded-2xl border border-rose-500/20 relative overflow-hidden">
        <div class="absolute right-0 top-0 translate-x-12 -translate-y-12 w-32 h-32 bg-brand-primary/10 rounded-full blur-2xl"></div>
        <span class="text-xs font-bold uppercase tracking-wider text-rose-400 px-2 py-0.5 bg-rose-500/10 rounded-md">Your Growth Summary</span>
        <h3 class="text-lg font-bold text-slate-100 mt-4" id="growth-title">Getting to know you...</h3>
        <p class="text-sm text-slate-300 mt-2 max-w-2xl leading-relaxed" id="growth-insight"></p>
        <div class="mt-5 glass p-4 rounded-xl border border-brand-border/40">
          <span class="text-[10px] font-bold uppercase tracking-wider text-violet-400">Recommended Next Step</span>
          <p class="text-sm text-slate-200 mt-1" id="growth-next"></p>
          <a id="growth-next-link" href="/dashboard" class="inline-block mt-3 px-4 py-2 text-xs font-bold uppercase tracking-wider text-white bg-linear-to-r from-rose-500 to-violet-500 rounded-full hover:scale-105 transition">Go There Now</a>
        </div>
      </div>

      <!-- ACTIVITY TIMELINE -->
      <div class="glass p-6 rounded-2xl">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-200 mb-4 border-b border-brand-border/40 pb-3">Activity History</h3>
        <div class="hidden sm:block overflow-x-auto">
          <table class="w-full text-left text-xs">
            <thead>
              <tr class="border-b border-brand-border/40 text-slate-500 font-semibold">
                <th class="pb-3">Date</th>
                <th class="pb-3">Feature</th>
                <th class="pb-3">Details</th>
                <th class="pb-3">Score/Output</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-brand-border/30" id="prog-timeline-table"></tbody>
          </table>
        </div>
        <div class="sm:hidden space-y-3" id="prog-timeline-mobile"></div>
      </div>

    </div>
  </div>

  <!-- SHARE CARD MODAL -->
  <div id="share-modal" class="hidden fixed inset-0 z-[100] bg-brand-dark/95 backdrop-blur-sm flex items-center justify-center px-4">
    <div class="w-full max-w-md glass rounded-3xl border border-brand-border/60 p-6 sm:p-8 relative">
      <button id="share-close" class="absolute top-4 right-4 text-slate-400 hover:text-white transition cursor-pointer">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <h3 class="text-lg font-bold text-slate-100 mb-1">Share Progress Card</h3>
      <p class="text-xs text-slate-400 mb-5">Privacy-safe — only shows stats, never conversations, names, or personal details.</p>
      <div id="share-card-preview" class="rounded-xl overflow-hidden border border-brand-border/40 mb-5">
        <canvas id="share-canvas" width="400" height="520" class="w-full block"></canvas>
      </div>
      <div class="flex gap-3">
        <button id="share-download" class="flex-1 py-3 text-xs font-bold uppercase tracking-wider text-white bg-linear-to-r from-rose-500 to-violet-500 hover:from-rose-600 hover:to-violet-600 rounded-xl transition cursor-pointer">Download PNG</button>
        <button id="share-copy" class="flex-1 py-3 text-xs font-bold uppercase tracking-wider text-slate-300 bg-slate-800 hover:bg-slate-700 border border-brand-border rounded-xl transition cursor-pointer">Copy to Clipboard</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var KEYS = {
        user: "rizzora_user",
        scoreHistory: "rizzora_score_history",
        simulator: "rizzora_simulator",
        crushMode: "rizzora_crush_mode",
        interestCheck: "rizzora_interest_check",
        profileScores: "rizzora_profile_scores",
        challenge: "rizzora_challenge",
        flirtCoach: "rizzora_flirt_coach",
        wsti: "rizzora_wsti",
        datePlans: "rizzora_date_plans"
      };

      function load(key) {
        try { var r = localStorage.getItem(key); return r ? JSON.parse(r) : null; }
        catch { return null; }
      }
      function loadArr(key) { var d = load(key); return Array.isArray(d) ? d : []; }

      var user = load(KEYS.user) || {};
      var scoreHistory = loadArr(KEYS.scoreHistory);
      var simSessions = loadArr(KEYS.simulator);
      var crushActivities = loadArr(KEYS.crushMode);
      var interestChecks = loadArr(KEYS.interestCheck);
      var profileScores = loadArr(KEYS.profileScores);
      var challenge = load(KEYS.challenge) || { completedDays: [], streak: 0, longestStreak: 0, totalXP: 0, bonusDays: [], badgesUnlocked: [], milestonesUnlocked: [] };
      var flirtActivities = loadArr(KEYS.flirtCoach);
      var wstiActivities = loadArr(KEYS.wsti);
      var datePlans = loadArr(KEYS.datePlans);

      var totalActivities = scoreHistory.length + simSessions.length + crushActivities.length + interestChecks.length + profileScores.length + (challenge.completedDays ? challenge.completedDays.length : 0) + flirtActivities.length + wstiActivities.length + datePlans.length;

      if (totalActivities === 0) {
        document.getElementById("prog-empty").classList.remove("hidden");
        document.getElementById("prog-content").classList.add("hidden");
        return;
      }
      document.getElementById("prog-empty").classList.add("hidden");
      document.getElementById("prog-content").classList.remove("hidden");

      if (user.name) {
        document.getElementById("prog-greeting").textContent = user.name + "'s Progress";
      }

      // XP & Level
      var xpThresholds = [0, 500, 1500, 3000, 5000, 8000, 12000, 17000, 23000];
      var levelTitles = ["Curious Learner", "Growing Communicator", "Empathetic Communicator", "Smooth Operator", "Confident Connector", "Rizz Master", "Dating Legend", "Elite Rizzler", "Rizz God"];
      var totalXP = user.xp || 0;
      if (challenge.totalXP) totalXP += challenge.totalXP;
      totalXP += crushActivities.length * 80;
      totalXP += interestChecks.length * 40;
      totalXP += profileScores.length * 50;
      totalXP += flirtActivities.length * 30;
      totalXP += wstiActivities.length * 30;
      totalXP += datePlans.length * 60;

      var currentLevel = 1;
      var levelTitle = levelTitles[0];
      for (var i = xpThresholds.length - 1; i >= 0; i--) {
        if (totalXP >= xpThresholds[i]) { currentLevel = i + 1; levelTitle = levelTitles[i]; break; }
      }

      // Rizz Score
      var scoreHistoryScores = scoreHistory.map(function (s) { return s.overall || 0; });
      var latestScore = scoreHistoryScores.length > 0 ? scoreHistoryScores[0] : (user.lastScore || 0);
      var prevScore = scoreHistoryScores.length > 1 ? scoreHistoryScores[1] : latestScore;
      var scoreChange = latestScore - prevScore;

      // Streak
      var mainStreak = user.streak || challenge.streak || 0;

      // Quick Stats
      document.getElementById("qs-rizz-score").textContent = latestScore + "/100";
      document.getElementById("qs-rizz-change").textContent = scoreChange > 0 ? "+" + scoreChange + " pts improvement" : scoreChange < 0 ? scoreChange + " pts to recover" : "Steady performance";
      document.getElementById("qs-xp").textContent = totalXP.toLocaleString();
      document.getElementById("qs-level").textContent = "Level " + currentLevel + " — " + levelTitle;
      document.getElementById("qs-streak").textContent = mainStreak + " Day" + (mainStreak !== 1 ? "s" : "");
      document.getElementById("qs-streak-sub").textContent = mainStreak >= 7 ? "On fire!" : mainStreak >= 3 ? "Building momentum" : "Keep going!";
      document.getElementById("qs-total").textContent = totalActivities;

      var featuresUsedCount = 0;
      if (simSessions.length) featuresUsedCount++;
      if (crushActivities.length) featuresUsedCount++;
      if (interestChecks.length) featuresUsedCount++;
      if (profileScores.length) featuresUsedCount++;
      if (flirtActivities.length) featuresUsedCount++;
      if (wstiActivities.length) featuresUsedCount++;
      if (datePlans.length) featuresUsedCount++;
      if (scoreHistory.length) featuresUsedCount++;
      if (challenge.completedDays && challenge.completedDays.length) featuresUsedCount++;
      document.getElementById("qs-total-sub").textContent = featuresUsedCount + " features used";

      // Rizz Score Chart
      (function () {
        var container = document.getElementById("chart-rizz-bars");
        var labelsEl = document.getElementById("chart-rizz-labels");
        if (!scoreHistoryScores.length) {
          container.innerHTML = '<div class="flex items-center justify-center w-full text-[10px] text-slate-500">No score data yet</div>';
          return;
        }
        var displayScores = scoreHistoryScores.slice(0, 14).reverse();
        var maxScore = Math.max.apply(null, displayScores.concat([100]));
        var colors = ["#db2777","#a855f7","#6366f1","#3b82f6","#10b981","#f59e0b","#ef4444","#ec4899","#8b5cf6","#6366f1","#3b82f6","#10b981","#f59e0b","#ef4444"];
        var html = "";
        for (var i = 0; i < displayScores.length; i++) {
          var h = Math.max(8, (displayScores[i] / maxScore) * 100);
          html += '<div class="flex-1 rounded-t-sm transition-all duration-700 hover:opacity-80" style="height:' + h + '%;background:' + colors[i % colors.length] + ';opacity:0.8" title="Score: ' + displayScores[i] + '"></div>';
        }
        container.innerHTML = html;
        var lhtml = "";
        for (var i = 0; i < displayScores.length; i++) {
          lhtml += '<span>' + (i % 3 === 0 ? displayScores[i] : '') + '</span>';
        }
        labelsEl.innerHTML = lhtml;
      })();

      // XP Growth Chart
      (function () {
        var container = document.getElementById("chart-xp-bars");
        var labelsEl = document.getElementById("chart-xp-labels");
        var xpTimeline = scoreHistory.map(function (s) { return s.xp || 0; }).reverse();
        if (xpTimeline.length < 2) {
          xpTimeline = [Math.max(0, totalXP - 300), Math.max(0, totalXP - 200), Math.max(0, totalXP - 100), totalXP];
        }
        var maxXP = Math.max.apply(null, xpTimeline.concat([1]));
        var html = "";
        for (var i = 0; i < xpTimeline.length; i++) {
          var h = Math.max(8, (xpTimeline[i] / maxXP) * 100);
          html += '<div class="flex-1 rounded-t-sm transition-all duration-700" style="height:' + h + '%;background:linear-gradient(to top, #8b5cf6, #db2777);opacity:0.8" title="XP: ' + xpTimeline[i] + '"></div>';
        }
        container.innerHTML = html;
        var lhtml = "";
        for (var i = 0; i < xpTimeline.length; i++) {
