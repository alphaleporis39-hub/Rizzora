      function loadChallengeActivity() {
        try {
          var raw = localStorage.getItem("rizzora_challenge");
          if (!raw) return;
          var ch = JSON.parse(raw);
          if (!ch || !ch.completedDays || !ch.completedDays.length) return;
          var feed = document.querySelector("#dash-activity-list");
          if (!feed) return;
          var li = document.createElement("li");
          li.innerHTML =
            '<div class="relative pb-8">' +
            '<span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-brand-border/40" aria-hidden="true"></span>' +
            '<div class="relative flex space-x-3">' +
            '<div><span class="h-8 w-8 rounded-full bg-slate-900 flex items-center justify-center text-xs">&#128293;</span></div>' +
            '<div class="flex-grow pt-0.5">' +
            '<div class="flex justify-between items-start">' +
            '<p class="text-xs font-bold text-slate-200">30-Day Challenge: Day ' + ch.completedDays.length + '/30</p>' +
            '<span class="text-[10px] text-slate-500">Active</span>' +
            '</div>' +
            '<p class="text-xs text-slate-400 mt-0.5">Streak: ' + (ch.streak || 0) + ' days | XP: ' + (ch.totalXP || 0) + '</p>' +
            '<span class="inline-block mt-1 text-[10px] font-semibold text-amber-400 px-1.5 py-0.2 bg-amber-500/10 rounded">' + (ch.completedDays.length * 3) + '% complete</span>' +
            '</div></div></div>';
          feed.insertBefore(li, feed.firstChild);
        } catch (e) {}
      }

      // --- Initialize ---
      var user = loadUser();
      if (user && user.name) {
        // Returning user — show dashboard directly
        if (overlay) overlay.classList.add("hidden");
        if (dashboardContent) dashboardContent.classList.remove("hidden");
        personalizeDashboard(user);
      } else {
        // First visit — show onboarding, hide dashboard content until complete
        if (dashboardContent) dashboardContent.classList.add("hidden");
        if (overlay) overlay.classList.remove("hidden");
        showStep(0);
      }

      // --- Step 1: Get Started ---
      document.getElementById("onb-start-btn").addEventListener("click", function () {
        showStep(1);
        setTimeout(function () {
          document.getElementById("onb-name-input").focus();
        }, 100);
      });

      // --- Step 2: Name ---
      document.getElementById("onb-name-next").addEventListener("click", function () {
        var name = document.getElementById("onb-name-input").value.trim();
        if (!name) {
          document.getElementById("onb-name-input").classList.add("ring-2", "ring-red-500/50");
          document.getElementById("onb-name-input").focus();
          setTimeout(function () {
            document.getElementById("onb-name-input").classList.remove("ring-2", "ring-red-500/50");
          }, 1500);
          return;
        }
        saveUser({ name: name, crushName: "" });
        showStep(2);
        setTimeout(function () {
          document.getElementById("onb-crush-input").focus();
        }, 100);
      });

      document.getElementById("onb-name-input").addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
          document.getElementById("onb-name-next").click();
        }
      });

      // --- Step 3: Crush ---
      document.getElementById("onb-crush-skip").addEventListener("click", function () {
        finishOnboarding();
      });

      document.getElementById("onb-crush-save").addEventListener("click", function () {
        var crushName = document.getElementById("onb-crush-input").value.trim();
        var user = loadUser();
        if (user) {
          user.crushName = crushName;
          saveUser(user);
        }
        finishOnboarding();
      });

      document.getElementById("onb-crush-input").addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
          document.getElementById("onb-crush-save").click();
        }
      });

      function finishOnboarding() {
        // Fade out overlay
        overlay.style.transition = "opacity 0.3s ease";
        overlay.style.opacity = "0";
        setTimeout(function () {
          overlay.classList.add("hidden");
          overlay.style.opacity = "";
          overlay.style.transition = "";
          // Show and personalize dashboard
          dashboardContent.classList.remove("hidden");
          personalizeDashboard(loadUser());
        }, 300);
      }
    })();
  </script>
</Layout>
