---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
---

<Layout title="Conversation Simulator | Rizzora">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-10">

    <!-- Header -->
    <div class="mb-6 sm:mb-8">
      <a href="/dashboard" class="text-xs font-semibold text-rose-400 hover:underline flex items-center gap-1 mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Dashboard
      </a>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Conversation Simulator</h1>
      <p class="text-slate-400 mt-1 text-sm sm:text-base">Practice real dating conversations with AI-powered characters. Get live feedback on your flow.</p>
    </div>

    <!-- ═══════════ SETUP SCREEN ═══════════ -->
    <div id="sim-setup" class="max-w-2xl mx-auto">
      <div class="glass p-6 sm:p-8 rounded-2xl space-y-5">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-300 border-b border-brand-border/40 pb-2">Setup Your Scenario</h3>

        <!-- Other Person's Name -->
        <div>
          <label class="block text-xs font-semibold text-slate-400 mb-1">Other person's name</label>
          <input id="sim-name" type="text" maxlength="20" placeholder="e.g. Sarah" class="w-full bg-slate-900/80 border border-brand-border rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-rose-500/50 transition" />
        </div>

        <!-- Language -->
        <div>
          <label class="block text-xs font-semibold text-slate-400 mb-2">Language</label>
          <div class="flex gap-2">
            <button data-lang="english" class="sim-lang-btn flex-1 py-2.5 text-xs font-bold uppercase tracking-wider rounded-xl border-2 border-rose-500 bg-rose-500/10 text-rose-400 cursor-pointer transition">English</button>
            <button data-lang="hinglish" class="sim-lang-btn flex-1 py-2.5 text-xs font-bold uppercase tracking-wider rounded-xl border-2 border-brand-border/60 bg-slate-900/40 text-slate-300 hover:border-slate-600 cursor-pointer transition">Hinglish</button>
          </div>
        </div>

        <!-- Scenario -->
        <div>
          <label class="block text-xs font-semibold text-slate-400 mb-2">Scenario</label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2" id="sim-scenario-grid">
            <button data-scenario="first_meeting" class="sim-scenario-btn text-left p-3 rounded-xl border-2 border-rose-500 bg-rose-500/10 transition cursor-pointer">
              <span class="text-sm font-bold text-rose-400 block">First Meeting</span>
              <span class="text-[10px] text-slate-400">Coffee shop, casual encounter</span>
            </button>
            <button data-scenario="crush" class="sim-scenario-btn text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">Talking to Crush</span>
              <span class="text-[10px] text-slate-400">Someone you like, building rapport</span>
            </button>
            <button data-scenario="dating_app" class="sim-scenario-btn text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">Dating App</span>
              <span class="text-[10px] text-slate-400">First text on a dating app</span>
            </button>
            <button data-scenario="first_date" class="sim-scenario-btn text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">First Date</span>
              <span class="text-[10px] text-slate-400">Real date, getting to know them</span>
            </button>
            <button data-scenario="custom" class="sim-scenario-btn col-span-1 sm:col-span-2 text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">Custom Scenario</span>
              <span class="text-[10px] text-slate-400">Create your own situation</span>
            </button>
          </div>
        </div>

        <!-- Custom scenario input (hidden by default) -->
        <div id="sim-custom-wrap" class="hidden">
          <label class="block text-xs font-semibold text-slate-400 mb-1">Describe your scenario</label>
          <textarea id="sim-custom" rows="2" maxlength="200" placeholder="e.g. You meet at a bookstore and bond over sci-fi novels" class="w-full bg-slate-900/80 border border-brand-border rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-rose-500/50 transition resize-none"></textarea>
        </div>

        <!-- Personality -->
        <div>
          <label class="block text-xs font-semibold text-slate-400 mb-2">Their personality</label>
          <div class="grid grid-cols-2 gap-2" id="sim-personality-grid">
            <button data-personality="friendly" class="sim-personality-btn text-left p-3 rounded-xl border-2 border-rose-500 bg-rose-500/10 transition cursor-pointer">
              <span class="text-sm font-bold text-rose-400 block">Friendly</span>
              <span class="text-[10px] text-slate-400">Warm, open, easy to talk to</span>
            </button>
            <button data-personality="shy" class="sim-personality-btn text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">Shy</span>
              <span class="text-[10px] text-slate-400">Reserved, warms up slowly</span>
            </button>
            <button data-personality="playful" class="sim-personality-btn text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">Playful</span>
              <span class="text-[10px] text-slate-400">Loves banter and teasing</span>
            </button>
            <button data-personality="hard_to_read" class="sim-personality-btn text-left p-3 rounded-xl border-2 border-brand-border/60 bg-slate-900/40 transition cursor-pointer">
              <span class="text-sm font-bold text-slate-300 block">Hard to Read</span>
              <span class="text-[10px] text-slate-400">Mysterious, gives short replies</span>
            </button>
          </div>
        </div>

        <!-- Start Button -->
        <button id="sim-start-btn" class="w-full py-3.5 text-sm font-bold uppercase tracking-wider text-white bg-linear-to-r from-rose-500 to-violet-500 hover:from-rose-600 hover:to-violet-600 rounded-2xl transition-all duration-200 shadow-lg shadow-rose-500/25 hover:shadow-rose-500/40 cursor-pointer active:scale-95">
          Start Conversation
        </button>
      </div>
    </div>

    <!-- ═══════════ CHAT SCREEN ═══════════ -->
    <div id="sim-chat" class="hidden grid grid-cols-1 lg:grid-cols-4 gap-6 lg:gap-8">

      <!-- Chat Area -->
      <div class="lg:col-span-3 glass rounded-2xl flex flex-col h-[450px] sm:h-[550px]">
        <!-- Chat Header -->
        <div class="px-4 sm:px-6 py-4 border-b border-brand-border/60 flex items-center justify-between flex-wrap gap-2">
          <div class="flex items-center space-x-3">
            <div id="sim-avatar" class="w-10 h-10 rounded-full bg-slate-800 border border-brand-border flex items-center justify-center font-bold text-rose-400 text-sm">S</div>
            <div>
              <h4 id="sim-chat-name" class="text-sm font-bold text-slate-200">Sarah</h4>
              <span id="sim-chat-scenario" class="text-[10px] text-slate-400">First Meeting</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span id="sim-msg-count" class="text-[10px] text-slate-500">0 messages</span>
            <button id="sim-end-btn" class="text-[10px] font-bold uppercase tracking-wider text-amber-400 bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 px-3 py-1.5 rounded-lg transition cursor-pointer">End Chat</button>
          </div>
        </div>

        <!-- Chat Messages -->
        <div id="sim-messages" class="flex-grow p-4 sm:p-6 overflow-y-auto space-y-4"></div>

        <!-- Chat Input -->
        <div class="p-4 border-t border-brand-border/60 bg-slate-950/40 rounded-b-2xl">
          <div class="flex items-center space-x-2">
            <input id="sim-input" type="text" maxlength="300" placeholder="Type your message..." class="flex-grow bg-slate-900 border border-brand-border rounded-xl px-4 py-3 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-rose-500/30 transition" />
            <button id="sim-send-btn" class="bg-rose-500 hover:bg-rose-600 text-white p-3 rounded-xl transition cursor-pointer active:scale-95">
              <svg class="w-4 h-4 transform rotate-90" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Live Metrics Sidebar -->
      <div class="lg:col-span-1 glass p-5 rounded-2xl flex flex-col">
        <h3 class="text-sm font-bold uppercase tracking-wider text-slate-300 mb-4 border-b border-brand-border/40 pb-2">Live Feedback</h3>
        <div class="space-y-4 flex-grow" id="sim-metrics">
          <div>
            <div class="flex justify-between text-xs mb-1"><span class="text-slate-300">Confidence</span><span class="font-bold text-slate-100" id="m-confidence">50%</span></div>
            <div class="w-full bg-slate-900 rounded-full h-1.5"><div class="bg-rose-500 h-1.5 rounded-full transition-all duration-500" id="bar-confidence" style="width:50%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-1"><span class="text-slate-300">Humor</span><span class="font-bold text-slate-100" id="m-humor">30%</span></div>
            <div class="w-full bg-slate-900 rounded-full h-1.5"><div class="bg-amber-500 h-1.5 rounded-full transition-all duration-500" id="bar-humor" style="width:30%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-1"><span class="text-slate-300">Flow</span><span class="font-bold text-slate-100" id="m-flow">50%</span></div>
            <div class="w-full bg-slate-900 rounded-full h-1.5"><div class="bg-blue-500 h-1.5 rounded-full transition-all duration-500" id="bar-flow" style="width:50%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-1"><span class="text-slate-300">Listening</span><span class="font-bold text-slate-100" id="m-listening">40%</span></div>
            <div class="w-full bg-slate-900 rounded-full h-1.5"><div class="bg-indigo-500 h-1.5 rounded-full transition-all duration-500" id="bar-listening" style="width:40%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-1"><span class="text-slate-300">Flirting</span><span class="font-bold text-slate-100" id="m-flirting">25%</span></div>
            <div class="w-full bg-slate-900 rounded-full h-1.5"><div class="bg-pink-500 h-1.5 rounded-full transition-all duration-500" id="bar-flirting" style="width:25%"></div></div>
          </div>
          <div>
            <div class="flex justify-between text-xs mb-1"><span class="text-slate-300">Respect</span><span class="font-bold text-slate-100" id="m-respect">70%</span></div>
            <div class="w-full bg-slate-900 rounded-full h-1.5"><div class="bg-emerald-500 h-1.5 rounded-full transition-all duration-500" id="bar-respect" style="width:70%"></div></div>
          </div>
        </div>
        <div class="pt-4 border-t border-brand-border/20 mt-4">
          <div class="text-center">
            <span class="text-[10px] text-slate-500">Overall Vibe</span>
            <div id="sim-vibe" class="text-lg font-bold text-emerald-400 mt-0.5">Good Start</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════ SUMMARY SCREEN ═══════════ -->
    <div id="sim-summary" class="hidden max-w-3xl mx-auto space-y-6">
      <div class="glass p-6 sm:p-8 rounded-2xl text-center">
        <div class="text-5xl mb-4">🏆</div>
        <h2 class="text-2xl font-extrabold text-white">Simulation Complete</h2>
        <p id="sum-scenario" class="text-slate-400 mt-1 text-sm"></p>
      </div>

      <!-- Score Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3" id="sum-scores"></div>

      <!-- Strengths & Mistakes -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="glass p-5 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-emerald-400 mb-3">Strengths</h3>
          <ul id="sum-strengths" class="space-y-2"></ul>
        </div>
        <div class="glass p-5 rounded-2xl">
          <h3 class="text-sm font-bold uppercase tracking-wider text-amber-400 mb-3">Mistakes</h3>
          <ul id="sum-mistakes" class="space-y-2"></ul>
        </div>
      </div>

      <!-- Tips -->
      <div class="glass p-5 rounded-2xl">
        <h3 class="text-sm font-bold uppercase tracking-wider text-violet-400 mb-3">Improvement Tips</h3>
        <ul id="sum-tips" class="space-y-2"></ul>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-3">
        <button id="sim-restart-btn" class="flex-1 py-3 text-sm font-bold uppercase tracking-wider text-white bg-linear-to-r from-rose-500 to-violet-500 hover:from-rose-600 hover:to-violet-600 rounded-2xl transition cursor-pointer">Restart Same Scenario</button>
        <button id="sim-another-btn" class="flex-1 py-3 text-sm font-bold uppercase tracking-wider text-slate-300 bg-slate-800 hover:bg-slate-700 border border-brand-border rounded-2xl transition cursor-pointer">Try Another Scenario</button>
        <a href="/dashboard" class="flex-1 py-3 text-sm font-bold uppercase tracking-wider text-slate-300 bg-slate-800 hover:bg-slate-700 border border-brand-border rounded-2xl transition text-center">Back to Dashboard</a>
      </div>
    </div>
  </div>
</Layout>

  <script is:inline>
    (function () {
      var ACT_KEY = "rizzora_simulator";
      function loadActivity() { try { var r = localStorage.getItem(ACT_KEY); return r ? JSON.parse(r) : []; } catch { return []; } }
      function saveActivity(list) { localStorage.setItem(ACT_KEY, JSON.stringify(list.slice(0, 30))); }
      function pushActivity(entry) { var list = loadActivity(); list.unshift(entry); saveActivity(list); }
      function q(a, b, c) { var s = String.fromCharCode(a); if (b) s += String.fromCharCode(b); if (c) s += String.fromCharCode(c); return s; }

      var selectedLang = "english";
      var selectedScenario = "first_meeting";
      var selectedPersonality = "friendly";
      var customScenario = "";
      var theirName = "Alex";
      var chatHistory = [];
      var msgCount = 0;
      var metrics = { confidence: 50, humor: 30, flow: 50, listening: 40, flirting: 25, respect: 70 };
      var sessionActive = false;

      var scenarioLabels = {
        first_meeting: "First Meeting",
        crush: "Talking to Crush",
        dating_app: "Dating App",
        first_date: "First Date",
        custom: "Custom Scenario"
      };

      // --- Setup: Language ---
      document.querySelectorAll(".sim-lang-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
          document.querySelectorAll(".sim-lang-btn").forEach(function (b) {
            b.classList.remove("border-rose-500", "bg-rose-500/10", "text-rose-400");
            b.classList.add("border-brand-border/60", "bg-slate-900/40", "text-slate-300");
          });
          btn.classList.add("border-rose-500", "bg-rose-500/10", "text-rose-400");
          btn.classList.remove("border-brand-border/60", "bg-slate-900/40", "text-slate-300");
          selectedLang = btn.getAttribute("data-lang");
        });
      });

      // --- Setup: Scenario ---
      document.querySelectorAll(".sim-scenario-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
          document.querySelectorAll(".sim-scenario-btn").forEach(function (b) {
            b.classList.remove("border-rose-500", "bg-rose-500/10");
            b.classList.add("border-brand-border/60", "bg-slate-900/40");
            var lbl = b.querySelector("span:first-child");
            if (lbl) { lbl.classList.remove("text-rose-400"); lbl.classList.add("text-slate-300"); }
          });
          btn.classList.add("border-rose-500", "bg-rose-500/10");
          btn.classList.remove("border-brand-border/60", "bg-slate-900/40");
          var lbl = btn.querySelector("span:first-child");
          if (lbl) { lbl.classList.add("text-rose-400"); lbl.classList.remove("text-slate-300"); }
          selectedScenario = btn.getAttribute("data-scenario");
          var cw = document.getElementById("sim-custom-wrap");
          if (selectedScenario === "custom") cw.classList.remove("hidden");
          else cw.classList.add("hidden");
        });
      });

      // --- Setup: Personality ---
      document.querySelectorAll(".sim-personality-btn").forEach(function (btn) {
        btn.addEventListener("click", function () {
          document.querySelectorAll(".sim-personality-btn").forEach(function (b) {
            b.classList.remove("border-rose-500", "bg-rose-500/10");
            b.classList.add("border-brand-border/60", "bg-slate-900/40");
            var lbl = b.querySelector("span:first-child");
            if (lbl) { lbl.classList.remove("text-rose-400"); lbl.classList.add("text-slate-300"); }
          });
          btn.classList.add("border-rose-500", "bg-rose-500/10");
          btn.classList.remove("border-brand-border/60", "bg-slate-900/40");
          var lbl = btn.querySelector("span:first-child");
          if (lbl) { lbl.classList.add("text-rose-400"); lbl.classList.remove("text-slate-300"); }
          selectedPersonality = btn.getAttribute("data-personality");
        });
      });

      // --- Start ---
      document.getElementById("sim-start-btn").addEventListener("click", function () {
        var nameInput = document.getElementById("sim-name");
        theirName = nameInput.value.trim() || "Alex";
        if (selectedScenario === "custom") {
          customScenario = document.getElementById("sim-custom").value.trim();
          if (!customScenario) {
            document.getElementById("sim-custom").classList.add("ring-2", "ring-red-500/50");
            document.getElementById("sim-custom").focus();
            setTimeout(function () { document.getElementById("sim-custom").classList.remove("ring-2", "ring-red-500/50"); }, 1500);
            return;
          }
        }
        startChat();
      });
      function startChat() {
        document.getElementById("sim-setup").classList.add("hidden");
        document.getElementById("sim-chat").classList.remove("hidden");
        document.getElementById("sim-chat").classList.add("grid");

        theirName = theirName.charAt(0).toUpperCase() + theirName.slice(1);
        document.getElementById("sim-chat-name").textContent = theirName;
        document.getElementById("sim-chat-scenario").textContent = scenarioLabels[selectedScenario] + " | " + selectedPersonality.charAt(0).toUpperCase() + selectedPersonality.slice(1);
        document.getElementById("sim-avatar").textContent = theirName.charAt(0);

        chatHistory = [];
        msgCount = 0;
        metrics = { confidence: 50, humor: 30, flow: 50, listening: 40, flirting: 25, respect: 70 };
        sessionActive = true;
        updateMetrics();
        document.getElementById("sim-messages").innerHTML = "";

        var greeting = getGreeting();
        addMessage(theirName, greeting, "them");
        pushToHistory("them", greeting);
      }

      function getGreeting() {
        var isHL = selectedLang === "hinglish";
        var s = selectedScenario;
        var p = selectedPersonality;
        var greetings = {
          first_meeting: {
            friendly: isHL ? "Hey! Tum bhi yahan ho? Kya ordered kiya hai?" : "Hey! You are here too? What did you order?",
            shy: isHL ? "Oh hi... tum bhi coffee lene aaye ho?" : "Oh hi... you are here for coffee too?",
            playful: isHL ? "Hey! Lagta hai hum same taste ke hain. Coffee lover ya tea person?" : "Hey! Looks like we have the same taste. Coffee lover or tea person?",
            hard_to_read: isHL ? "Hey." : "Hey."
          },
          crush: {
            friendly: isHL ? "Hey! Aaj ka din kaisa ja raha hai tumhara?" : "Hey! How is your day going so far?",
            shy: isHL ? "Hi... acha hua tum mil gaye. Mera din thoda boring tha." : "Hi... glad I ran into you. My day was a bit boring.",
            playful: isHL ? "Hey! Tumhe dekh ke laga ki aaj ka din accha ho jaayega. Prove me right. 😊" : "Hey! Seeing you just made my day better. Prove me right. 😊",
            hard_to_read: isHL ? "Hi. Kya chal raha hai?" : "Hi. What is up?"
          },
          dating_app: {
            friendly: isHL ? "Hey! Tumhara profile dekh ke muskuraya main. Kya interest hai tumhari?" : "Hey! Your profile made me smile. What are you into?",
            shy: isHL ? "Hi... hope ye message thoda awkward na lage. Tumhara bio accha hai." : "Hi... hope this is not awkward. Your bio is cool.",
            playful: isHL ? "Hey! Agar tumhe ek emoji se describe karna padega khud ko, kya hoga?" : "Hey! If you had to describe yourself in one emoji, what would it be?",
            hard_to_read: isHL ? "Hey. Profile acchi hai." : "Hey. Nice profile."
          },
          first_date: {
            friendly: isHL ? "Hey! Kaisa laga yahan aake? comfortable ho?" : "Hey! How are you feeling about this place? Comfortable?",
            shy: isHL ? "Hi... nervous nahi hu, bas thoda excited. Tum kaisi ho?" : "Hi... not nervous, just a bit excited. How are you?",
            playful: isHL ? "Hey! Date ka pehla impression kaisa raha? 10 mein se kitne number doge mujhe?" : "Hey! First impression of this date? How many points out of 10 would you give me?",
            hard_to_read: isHL ? "Hey. Yahan aake accha laga." : "Hey. Glad to be here."
          },
          custom: {
            friendly: isHL ? "Hey! Kaisa lag raha hai yahan?" : "Hey! How are you feeling here?",
            shy: isHL ? "Hi... thoda alag hai ye situation, but accha hai." : "Hi... this is a bit different, but nice.",
            playful: isHL ? "Hey! Ye situation toh interesting hai. Tum kya soch rahe ho?" : "Hey! This situation is interesting. What are you thinking?",
            hard_to_read: isHL ? "Hey." : "Hey."
          }
        };
        return greetings[s][p] || greetings[s].friendly;
      }
      function addMessage(sender, text, type) {
        var container = document.getElementById("sim-messages");
        var now = new Date();
        var time = now.getHours().toString().replace(/^(\d)$/, "0$1") + ":" + now.getMinutes().toString().replace(/^(\d)$/, "0$1");
        var isMe = type === "me";
        var wrap = document.createElement("div");
        wrap.className = "flex flex-col " + (isMe ? "items-end" : "items-start");
        wrap.innerHTML =
          '<div class="text-[10px] text-slate-500 mb-0.5">' + sender + '</div>' +
          '<div class="max-w-xs sm:max-w-sm px-4 py-2.5 rounded-2xl text-sm ' +
            (isMe ? 'bg-rose-500 text-white rounded-tr-none' : 'bg-slate-800 text-slate-200 rounded-tl-none') +
          '">' + text + '</div>' +
          '<div class="text-[9px] text-slate-600 mt-0.5">' + time + '</div>';
        container.appendChild(wrap);
        container.scrollTop = container.scrollHeight;
      }

      function pushToHistory(sender, text) {
        chatHistory.push({ sender: sender, text: text, ts: Date.now() });
      }

      function updateMetrics() {
        var keys = ["confidence", "humor", "flow", "listening", "flirting", "respect"];
        keys.forEach(function (k) {
          var val = Math.round(metrics[k]);
          var bar = document.getElementById("bar-" + k);
          var label = document.getElementById("m-" + k);
          if (bar) bar.style.width = val + "%";
          if (label) label.textContent = val + "%";
        });
        var avg = Math.round((metrics.confidence + metrics.humor + metrics.flow + metrics.listening + metrics.flirting + metrics.respect) / 6);
        var vibeEl = document.getElementById("sim-vibe");
        if (vibeEl) {
          if (avg >= 80) { vibeEl.textContent = "Amazing"; vibeEl.className = "text-lg font-bold text-emerald-400 mt-0.5"; }
          else if (avg >= 65) { vibeEl.textContent = "Great Flow"; vibeEl.className = "text-lg font-bold text-blue-400 mt-0.5"; }
          else if (avg >= 50) { vibeEl.textContent = "Good Start"; vibeEl.className = "text-lg font-bold text-amber-400 mt-0.5"; }
          else if (avg >= 35) { vibeEl.textContent = "Needs Work"; vibeEl.className = "text-lg font-bold text-orange-400 mt-0.5"; }
          else { vibeEl.textContent = "Awkward"; vibeEl.className = "text-lg font-bold text-red-400 mt-0.5"; }
        }
      }

      function analyzeUser(msg) {
        var m = msg.toLowerCase();
        var len = msg.length;
        var delta = { confidence: 0, humor: 0, flow: 0, listening: 0, flirting: 0, respect: 0 };

        if (len > 20) delta.confidence += 8;
        else if (len > 10) delta.confidence += 4;
        else delta.confidence -= 5;

        if (m.indexOf("?") > -1) delta.listening += 6;
        if (m.indexOf("you") > -1 || m.indexOf("tum") > -1 || m.indexOf("your") > -1) delta.listening += 4;
        if (m.indexOf("think") > -1 || m.indexOf("feel") > -1 || m.indexOf("sochte") > -1 || m.indexOf("lagta") > -1) delta.listening += 5;

        var humorWords = ["haha", "lol", "joke", "funny", "maza", "hahaha", "😂", "😄", ";)", ":P"];
        humorWords.forEach(function (w) { if (m.indexOf(w) > -1) delta.humor += 8; });

        var flirtWords = ["cute", "beautiful", "handsome", "adorable", "pyaari", "sundar", "love", "miss", "😊", "😄", "❤"];
        var flirtCount = 0;
        flirtWords.forEach(function (w) { if (m.indexOf(w) > -1) flirtCount++; });
        if (flirtCount === 1) delta.flirting += 6;
        else if (flirtCount >= 2) delta.flirting += 10;

        if (len > 30) delta.flow += 5;
        if (m.indexOf("and") > -1 || m.indexOf("aur") > -1) delta.flow += 3;

        var rudeWords = ["stupid", "idiot", "ugly", "shut up", "boring", "worst", "hate"];
        var hasRude = false;
        rudeWords.forEach(function (w) { if (m.indexOf(w) > -1) { hasRude = true; delta.respect -= 15; } });
        if (!hasRude) delta.respect += 2;

        var pushyWords = ["why didnt", "why not reply", "where are you", "answer me", " reply", "ignore"];
        pushyWords.forEach(function (w) { if (m.indexOf(w) > -1) { delta.respect -= 8; delta.confidence -= 5; } });

        return delta;
      }
      function generateResponse(userMsg, history, scenario, personality, lang) {
        var isHL = lang === "hinglish";
