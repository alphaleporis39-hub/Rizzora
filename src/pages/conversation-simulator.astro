        } else if (isFlirty) {
          if (p === "friendly") {
            responses = isHL
              ? ["Aww, thanks! Tum bhi kaafi acche ho, honestly. 😊", "Haha, ye sun ke accha laga! Par ab tumhari baari hai compliment dene ki. 😄", "That is sweet! Tumhe pata hai, tumhari baatein bhi acchi lagti hain. 😊"]
              : ["Aww, that is really sweet of you! You are pretty great too, honestly. 😊", "Ha, thanks! Now it is your turn to接受 a compliment. 😄", "That is nice to hear! Your messages are pretty great too. 😊"];
          } else if (p === "shy") {
            responses = isHL
              ? ["Oh... thanks. Tum bhi... accha ho. (blushing hu main abhi).", "Ye sun ke... accha laga. Par thoda shy ho rahi hu.", "Thanks... tumhari baatein bhi... acchi lagti hain."]
              : ["Oh... thanks. You are... nice too. (I am blushing right now).", "That is... sweet. I feel a bit shy now though.", "Thanks... your messages are... nice too."];
          } else if (p === "playful") {
            responses = isHL
              ? ["Haha, smooth! Tum expert ho kya? 😏", "Oho! Flirting skill level: expert. Main impressed hu. 😊", "Aww! Par ab ye prove bhi karo in person. ;)" ]
              : ["Haha, smooth! Are you a pro at this? 😏", "Oh wow! Flirting level: expert. I am impressed. 😊", "That is sweet! Now prove it in person. ;)"];
          } else {
            responses = isHL
              ? ["Accha.", "Hmm.", "Ok."]
              : ["Nice.", "Hmm.", "Ok."];
          }
        } else if (isDeep) {
          if (p === "friendly") {
            responses = isHL
              ? ["Ye gehri baat ho gayi! Par accha laga sun ke. Tum sochte ho bahut, ye acchi baat hai.", "Hmm, ye sochne wali baat hai. Main bhi kabhi kabhi aise sochti hu. Tumhare saath discuss karna accha lagta hai.", "Deep! Par sahi hai. Life mein aise conversations chahiye. Tum kya chahte ho life se?"]
              : ["That got deep! But I like it. You think a lot, that is a good quality.", "Hmm, that is something to think about. I have those moments too. Love discussing this with you.", "Deep! But in a good way. Life needs these conversations. What do you want from life?"];
          } else if (p === "shy") {
            responses = isHL
              ? ["Ye... gehri baat hai. Main itna sochti nahi hu aamtaur par, par ye accha laga.", "Hmm... main thoda nervous ho rahi hu ye discuss karne mein, par tumhare saath comfortable hu.", "Accha... ye sochne wali baat hai. Tumhare saath discuss karna accha lagta hai."]
              : ["This is... deep. I do not usually think this much, but this is nice.", "Hmm... I feel a bit nervous discussing this, but I am comfortable with you.", "Good point... something to think about. I like talking about this with you."];
          } else if (p === "playful") {
            responses = isHL
              ? ["Oho! philosopher ban gaye aaj? Par accha hai, depth bhi zaroori hai. 😊", "Deep! Ab thoda light bhi ho jaaye? ;). Par ye accha topic hai.", "Hmm, ye sun ke laga ki tum interesting ho. Par ab ek joke bhi sunao! 😄"]
              : ["Oh, going philosophical today! But I like it, depth is good too. 😊", "Deep stuff! Can we lighten it up a bit too? ;). But great topic.", "Hmm, this makes you interesting. But now tell me a joke! 😄"];
          } else {
            responses = isHL
              ? ["Hmm.", "Accha.", "Ye sochne wali baat hai."]
              : ["Hmm.", "Interesting.", "Something to think about."];
          }
        } else {
          if (p === "friendly") {
