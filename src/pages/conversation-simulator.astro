        var isBoring = m === "ok" || m === "hmm" || m === "k" || m === "cool" || m === "nm";
        var isRude = m.indexOf("stupid") > -1 || m.indexOf("ugly") > -1 || m.indexOf("boring") > -1 || m.indexOf("shut up") > -1;

        if (isRude) {
