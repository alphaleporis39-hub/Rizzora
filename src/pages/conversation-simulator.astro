            responses = isHL
              ? ["Wow, itna content! Main overwhelmed ho gayi. 😂", "Ye padh ke laga ki tumhare phone ka autocorrect bhi bore ho raha hai. 😂", "Itna effort dekh ke impressed hu! 😂"]
              : ["Wow, so much content! I am overwhelmed. 😂", "Even your phone's autocorrect is getting bored. 😂", "All that effort, wow! 😂"];
