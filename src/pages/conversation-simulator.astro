      // --- Send Message ---
      function sendMessage() {
        var input = document.getElementById("sim-input");
        var msg = input.value.trim();
        if (!msg || !sessionActive) return;
        input.value = "";

        addMessage("You", msg, "me");
        pushToHistory("me", msg);
        msgCount++;
        document.getElementById("sim-msg-count").textContent = msgCount + " messages";

        var delta = analyzeUser(msg);
        var keys = ["confidence", "humor", "flow", "listening", "flirting", "respect"];
        keys.forEach(function (k) {
          metrics[k] = Math.max(0, Math.min(100, metrics[k] + delta[k]));
        });
        updateMetrics();

        setTimeout(function () {
          var response = generateResponse(msg, chatHistory, selectedScenario, selectedPersonality, selectedLang);
          addMessage(theirName, response, "them");
          pushToHistory("them", response);

          if (selectedPersonality === "hard_to_read" && msgCount >= 8 && Math.random() > 0.5) {
            sessionActive = false;
            setTimeout(function () {
              addMessage(theirName, "I think I should head out now. It was nice talking to you.", "them");
              pushToHistory("them", "I think I should head out now. It was nice talking to you.");
              setTimeout(showSummary, 1500);
            }, 800);
          }
        }, 800 + Math.random() * 1200);
      }

      document.getElementById("sim-send-btn").addEventListener("click", sendMessage);
      document.getElementById("sim-input").addEventListener("keydown", function (e) {
        if (e.key === "Enter") sendMessage();
      });

      // --- End Chat ---
      document.getElementById("sim-end-btn").addEventListener("click", function () {
        if (!sessionActive) return;
        sessionActive = false;
        addMessage("You", "It was great talking to you! Take care. 😊", "me");
        pushToHistory("me", "It was great talking to you! Take care. 😊");
        msgCount++;
        setTimeout(function () {
          addMessage(theirName, "You too! Had a great time. Take care!", "them");
          pushToHistory("them", "You too! Had a great time. Take care!");
          setTimeout(showSummary, 1200);
        }, 1000);
      });

      function showSummary() {
        document.getElementById("sim-chat").classList.add("hidden");
        document.getElementById("sim-chat").classList.remove("grid");
        document.getElementById("sim-summary").classList.remove("hidden");

        document.getElementById("sum-scenario").textContent =
          scenarioLabels[selectedScenario] + " with " + theirName + " (" + selectedPersonality.charAt(0).toUpperCase() + selectedPersonality.slice(1) + ") | " + msgCount + " messages";

        var avg = Math.round((metrics.confidence + metrics.humor + metrics.flow + metrics.listening + metrics.flirting + metrics.respect) / 6);
        var scoreData = [
          { name: "Confidence", val: Math.round(metrics.confidence), color: "text-rose-400" },
          { name: "Humor", val: Math.round(metrics.humor), color: "text-amber-400" },
          { name: "Flow", val: Math.round(metrics.flow), color: "text-blue-400" },
          { name: "Listening", val: Math.round(metrics.listening), color: "text-indigo-400" },
          { name: "Flirting", val: Math.round(metrics.flirting), color: "text-pink-400" },
          { name: "Respect", val: Math.round(metrics.respect), color: "text-emerald-400" }
        ];
        var scoreHtml = "";
        scoreData.forEach(function (s) {
          scoreHtml += '<div class="glass p-4 rounded-xl text-center">' +
            '<div class="text-2xl font-extrabold ' + s.color + '">' + s.val + '%</div>' +
            '<div class="text-xs text-slate-400 mt-1">' + s.name + '</div></div>';
        });
        scoreHtml += '<div class="glass p-4 rounded-xl text-center col-span-2 sm:col-span-3">' +
          '<div class="text-3xl font-extrabold text-white">' + avg + '%</div>' +
          '<div class="text-xs text-slate-400 mt-1">Overall Score</div></div>';
        document.getElementById("sum-scores").innerHTML = scoreHtml;

        var strengths = [];
        if (metrics.respect >= 70) strengths.push("Showed genuine respect throughout the conversation.");
        if (metrics.listening >= 60) strengths.push("Asked thoughtful follow-up questions and engaged with their replies.");
        if (metrics.confidence >= 65) strengths.push("Communicated confidently with clear, well-formed messages.");
        if (metrics.humor >= 50) strengths.push("Added humor and lightness to keep the vibe fun.");
        if (metrics.flirting >= 50) strengths.push("Flirted naturally without being pushy or overwhelming.");
        if (metrics.flow >= 60) strengths.push("Maintained smooth conversation flow with good transitions.");
        if (strengths.length === 0) strengths.push("You completed the conversation! That takes courage. Keep practicing.");
        var sHtml = "";
        strengths.forEach(function (s) { sHtml += '<li class="flex items-start gap-2 text-xs text-slate-300"><span class="text-emerald-400 mt-0.5">&#10003;</span>' + s + '</li>'; });
        document.getElementById("sum-strengths").innerHTML = sHtml;

        var mistakes = [];
        if (metrics.respect < 60) mistakes.push("Some messages may have felt pushy or disrespectful. Focus on giving space.");
        if (metrics.listening < 50) mistakes.push("Try asking more questions about what they share instead of redirecting to yourself.");
        if (metrics.confidence < 50) mistakes.push("Messages were too short or uncertain. Try adding more detail and personality.");
        if (metrics.humor < 30 && metrics.flirting < 30) mistakes.push("The conversation lacked lightness. Add humor or playful energy to keep it fun.");
        if (msgCount < 6) mistakes.push("The conversation ended quickly. Try to sustain the flow with follow-up questions.");
        if (mistakes.length === 0) mistakes.push("No major mistakes! You kept things respectful and engaging.");
        var mHtml = "";
        mistakes.forEach(function (m) { mHtml += '<li class="flex items-start gap-2 text-xs text-slate-300"><span class="text-amber-400 mt-0.5">&#9888;</span>' + m + '</li>'; });
        document.getElementById("sum-mistakes").innerHTML = mHtml;

        var tips = [];
        if (metrics.flow < 60) tips.push("Practice the FORD method: Family, Occupation, Recreation, Dreams. It keeps conversations flowing naturally.");
        if (metrics.humor < 50) tips.push("Use playful teasing or situational humor. Avoid forced jokes; let humor come from the moment.");
        if (metrics.flirting < 50) tips.push("Add subtle compliments that feel genuine. Notice small things about them, not just appearance.");
        if (metrics.listening < 60) tips.push("Reflect back what they say: 'Oh you like hiking? What trails have you tried?' It shows real interest.");
        if (metrics.confidence < 60) tips.push("Speak with conviction. Instead of 'I guess so', try 'Absolutely!' or 'That sounds great.'");
        tips.push("After 5-6 exchanges, suggest moving to a different platform or meeting in person if the vibe is right.");
        var tHtml = "";
        tips.forEach(function (t) { tHtml += '<li class="flex items-start gap-2 text-xs text-slate-300"><span class="text-violet-400 mt-0.5">&#10148;</span>' + t + '</li>'; });
        document.getElementById("sum-tips").innerHTML = tHtml;

        pushActivity({
          type: "Simulator",
          name: scenarioLabels[selectedScenario] + " Simulation",
          detail: "With " + theirName + " (" + selectedPersonality + ")",
          score: avg + "% overall",
          date: new Date().toLocaleString(),
          scenario: selectedScenario,
          personality: selectedPersonality,
          theirName: theirName,
          messages: msgCount,
          metrics: {
            confidence: Math.round(metrics.confidence),
            humor: Math.round(metrics.humor),
            flow: Math.round(metrics.flow),
            listening: Math.round(metrics.listening),
            flirting: Math.round(metrics.flirting),
            respect: Math.round(metrics.respect)
          }
        });
      }

      // --- Restart ---
      document.getElementById("sim-restart-btn").addEventListener("click", function () {
        document.getElementById("sim-summary").classList.add("hidden");
        startChat();
      });

      document.getElementById("sim-another-btn").addEventListener("click", function () {
        document.getElementById("sim-summary").classList.add("hidden");
        document.getElementById("sim-chat").classList.add("hidden");
        document.getElementById("sim-chat").classList.remove("grid");
        document.getElementById("sim-setup").classList.remove("hidden");
      });
    })();
  </script>
