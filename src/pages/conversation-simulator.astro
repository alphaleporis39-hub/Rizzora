              ? ["Accha sawaal hai! Mere according to... (soch rahi hu). Tum kya sochte ho?", "Hmm, ye socha nahi tha. Par lagta hai... interesting! Tumhari baat mein dum hai.", "Good question! Mera answer hai... par tum sunna chahti ho ya already jaanti ho?"]
              : ["Good question! I would say... hmm, still thinking. What do you think?", "Interesting! I have not really thought about that. What is your take?", "Love that question! My answer is... honestly I am still deciding. How about you?"];
          } else if (p === "shy") {
            responses = isHL
              ? ["Ye... interesting hai. Mere paas abhi answer nahi hai, par sochungi.", "Hmm... accha hai ye sawaal. Par thoda nervous ho rahi hu answer dene mein.", "Mujhe nahi pata exactly... par tum batao kya sochte ho?"]
              : ["This is... interesting. I do not have an answer right now, but I will think about it.", "Hmm... that is a good question. I feel a bit nervous answering though.", "I am not sure exactly... but what do you think?"];
          } else if (p === "playful") {
            responses = isHL
              ? ["Oho! Ye ekdam trap question lag rahi hai. Par okay, mera answer hai... ab tumhari baari! ;)", "Interesting! Par pehle tum batao, tumhara answer kya hoga? Curious hu. 😏", "Accha! Main bhi ek sawaal puchu ya pehle ye solve karein? ;)"]
              : ["Okay this feels like a test... but my answer is... now your turn! ;)", "Good question! But I want to hear your answer first. Curious. 😏", "Nice! Should I answer first or should you? ;)"];
          } else {
